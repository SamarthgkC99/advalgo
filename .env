# UT Bot Environment Variables
# Copy this to .env and fill in values before running

# Flask port (Render sets this automatically)
PORT=5000

# Optional: Set a fixed USDT/INR rate here to skip auto-fetch on startup
# If blank, bot will auto-fetch from internet
# USDT_INR_RATE=85.0

# Optional: Override default lot size (BTC)
# LOT_SIZE_BTC=0.001
